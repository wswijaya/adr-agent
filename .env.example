# ── LLM provider ─────────────────────────────────────────────────────────────
# Required. One of: anthropic (default), openai, ollama, azure
LLM_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/

# Optional: override the default model for the selected provider
# LLM_MODEL=claude-opus-4-7

# ── Web search ────────────────────────────────────────────────────────────────
# At least one search provider is recommended. Without one, the agent
# falls back to the built-in knowledge base only.

# Tavily — recommended for structured technical results
# TAVILY_API_KEY=tvly-...

# Firecrawl
# FIRECRAWL_API_KEY=fc-...

# No-key providers: set to "duckduckgo" or "anthropic"
# WEB_SEARCH_PROVIDER=duckduckgo

# ── Output ────────────────────────────────────────────────────────────────────
# Directory where generated ADR markdown files are written.
# ADR_OUTPUT_DIR=./decisions

# Maximum number of confidence-check retry passes (default: 2).
# ADR_MAX_RETRIES=2
